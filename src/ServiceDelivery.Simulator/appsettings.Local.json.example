{
  "//": "Template for local-only config. Copy to appsettings.Local.json (gitignored) and fill in creds.",
  "//env": "Loaded only when DOTNET_ENVIRONMENT=Local. Same pattern applies to appsettings.Development.json, appsettings.Test.json, appsettings.Production.json via DOTNET_ENVIRONMENT.",
